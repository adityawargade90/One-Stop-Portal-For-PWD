# ──────────────────────────────────────────────────────────────────────────────
# DivyangConnect-AI  —  environment variable template
#
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Supabase (legacy – kept for backward compatibility) ─────────────────────
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get a free API key from: https://aistudio.google.com/apikey
# Used by the chatbot (Gemini 2.0 Flash model — free tier available)
VITE_GEMINI_API_KEY=

# ─── Google Maps ──────────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ─── MongoDB (Express backend) ───────────────────────────────────────────────
MONGO_URI=

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Get these values from:
#   Firebase Console → Project Settings → General → Your apps
#   → SDK setup and configuration → Config
#
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=        # optional — only needed for Google Analytics
